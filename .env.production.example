# SystemBook — template de variáveis de ambiente para PRODUÇÃO.
#
# Copie este arquivo para `.env` (que NÃO é commitado) e preencha os valores:
#   cp .env.production.example .env
# Depois: docker compose -f docker-compose.production.yml up -d
#
# Gere os segredos com valores fortes e aleatórios, ex.:
#   openssl rand -base64 32

# --- Obrigatórias ---

# Segredo usado para assinar os cookies de sessão. Trocar invalida as sessões.
SESSION_SECRET=

# Pepper concatenado no hash de senha (argon2id). NÃO mude depois de criar
# usuários — invalidaria todas as senhas existentes.
ARGON2_SECRET=

# Admin de bootstrap, criado automaticamente no primeiro boot (banco vazio).
# Depois disso, gerencie usuários pelo painel. Troque a senha após o 1º acesso.
INITIAL_ADMIN_EMAIL=admin@exemplo.com
INITIAL_ADMIN_PASSWORD=

# --- Opcionais (têm default na imagem; descomente só se quiser mudar) ---

# Porta HTTP exposta (default 3000).
# PORT=3000

# Caminho do arquivo SQLite. O default já fica no volume persistente. Se mudar,
# mantenha sob /app/data para não perder dados ao recriar o container.
# DATABASE_PATH=/app/data/systembook.db

# Diretório dos artefatos de preview (default /app/data/previews, no volume).
# PREVIEWS_PATH=/app/data/previews
