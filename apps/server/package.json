{
  "name": "@systembook/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=../../.env.local src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:seed": "tsx --env-file-if-exists=../../.env.local src/db/seed-cli.ts"
  },
  "dependencies": {
    "@systembook/schema": "workspace:*",
    "@trpc/server": "^11.0.0",
    "better-sqlite3": "^12.2.0",
    "drizzle-orm": "^0.44.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.0",
    "drizzle-kit": "^0.31.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
