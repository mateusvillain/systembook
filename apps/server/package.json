{
  "name": "@systembook/server",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/trpc/router.ts"
    }
  },
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=../../.env.local src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:seed": "tsx --env-file-if-exists=../../.env.local src/db/seed-cli.ts"
  },
  "dependencies": {
    "@systembook/schema": "workspace:*",
    "@trpc/server": "^11.0.0",
    "argon2": "^0.45.0",
    "better-sqlite3": "^12.2.0",
    "busboy": "^1.6.0",
    "drizzle-orm": "^0.44.0",
    "tar": "^7.5.20",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/busboy": "^1.5.4",
    "@types/node": "^22.13.0",
    "drizzle-kit": "^0.31.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
